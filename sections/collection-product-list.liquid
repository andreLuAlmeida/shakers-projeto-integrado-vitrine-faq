<section class="collection-product-list">
  <div class="page-width">
    {% assign selected_collection = section.settings.collection %}

    {% if section.settings.heading != blank or section.settings.text != blank %}
      <div class="collection-product-list__header">
        {% if section.settings.heading != blank %}
          <h2 class="collection-product-list__title">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="collection-product-list__text">
            {{ section.settings.text }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% if selected_collection != blank %}
      <div class="collection-product-list__grid">
        {% for product in selected_collection.products limit: section.settings.products_limit %}
          <a href="{{ product.url }}" class="collection-product-list__card">
            <div class="collection-product-list__image-wrapper">
              {% if product.featured_image %}
                <img
                  class="collection-product-list__image"
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  loading="lazy"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'collection-product-list__placeholder' }}
              {% endif %}
            </div>

            <div class="collection-product-list__content">
              <h3 class="collection-product-list__product-title">
                {{ product.title }}
              </h3>

              <p class="collection-product-list__price">
                {% if product.compare_at_price > product.price %}
                  <span class="collection-product-list__price--sale">
                    {{ product.price | money }}
                  </span>
                  <span class="collection-product-list__price--compare">
                    {{ product.compare_at_price | money }}
                  </span>
                {% else %}
                  <span class="collection-product-list__price--regular">
                    {{ product.price | money }}
                  </span>
                {% endif %}
              </p>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if section.settings.show_collection_button and selected_collection.url != blank %}
        <div class="collection-product-list__footer">
          <a href="{{ selected_collection.url }}" class="collection-product-list__button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="collection-product-list__empty">
        <p>Selecione uma coleção no editor da seção.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
        .collection-product-list {
        padding: 56px 0;
        }

        .collection-product-list__header {
        margin-bottom: 32px;
        text-align: center;
        }

        .collection-product-list__title {
        margin: 0 0 12px;
        font-size: 32px;
        line-height: 1.2;
        font-weight: 700;
        color: #111111;
        }

        .collection-product-list__text {
        margin: 0;
        font-size: 16px;
        line-height: 1.5;
        color: #666666;
        }

        .collection-product-list__grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 20px;
        }

        .collection-product-list__card {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .collection-product-list__card:hover {
        transform: translateY(-4px);
        }

        .collection-product-list__image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        border-radius: 14px;
        background: #f5f5f5;
        }

        .collection-product-list__image,
        .collection-product-list__placeholder {
        width: 100%;
        height: 100%;
        display: block;
        }

        .collection-product-list__image {
        object-fit: cover;
        }

        .collection-product-list__content {
        padding-top: 14px;
        }

        .collection-product-list__product-title {
        margin: 0 0 8px;
        font-size: 15px;
        line-height: 1.4;
        font-weight: 600;
        color: #111111;

        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        }

        .collection-product-list__price {
        margin: 0;
        font-size: 15px;
        line-height: 1.4;
        }

        .collection-product-list__price--regular {
        color: #111111;
        font-weight: 600;
        }

        .collection-product-list__price--sale {
        color: #111111;
        font-weight: 700;
        margin-right: 8px;
        }

        .collection-product-list__price--compare {
        color: #888888;
        text-decoration: line-through;
        font-weight: 400;
        }

        .collection-product-list__footer {
        margin-top: 32px;
        text-align: center;
        }

        .collection-product-list__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 24px;
        border-radius: 999px;
        background: #111111;
        color: #ffffff;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: opacity 0.25s ease, transform 0.25s ease;
        }

        .collection-product-list__button:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        }

        .collection-product-list__empty {
        text-align: center;
        padding: 32px 16px;
        background: #f8f8f8;
        border-radius: 12px;
        color: #666666;
        }

        @media screen and (max-width: 1200px) {
        .collection-product-list__grid {
            grid-template-columns: repeat(4, 1fr);
        }
        }

        @media screen and (max-width: 990px) {
        .collection-product-list {
            padding: 48px 0;
        }

        .collection-product-list__title {
            font-size: 28px;
        }

        .collection-product-list__grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }
        }

        @media screen and (max-width: 767px) {
        .collection-product-list__header {
            margin-bottom: 24px;
        }

        .collection-product-list__title {
            font-size: 24px;
        }

        .collection-product-list__text {
            font-size: 15px;
        }

        .collection-product-list__grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
        }

        @media screen and (max-width: 480px) {
        .collection-product-list__grid {
            grid-template-columns: 1fr;
        }
        }
</style>

{% schema %}
{
  "name": "Listagem de produtos",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Nossos produtos"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto de apoio",
      "default": "Confira alguns produtos desta coleção."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Quantidade de produtos exibidos",
      "min": 5,
      "max": 25,
      "step": 5,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_collection_button",
      "label": "Mostrar botão para coleção",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão",
      "default": "Ver coleção completa"
    }
  ],
  "presets": [
    {
      "name": "Listagem de produtos"
    }
  ]
}
{% endschema %}