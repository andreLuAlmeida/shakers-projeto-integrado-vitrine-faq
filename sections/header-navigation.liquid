{{ 'header-navigation.css' | asset_url | stylesheet_tag }}
{{ 'header-navigation.js' | asset_url | script_tag }}

<header class="header-navigation" id="header-navigation">
  <div class="header-navigation__container page-width">

    <a class="header-navigation__brand" href="{{ routes.root_url }}">
      {{ shop.name }}
    </a>

    <nav class="header-navigation__menu">

      <a href="{{ routes.root_url }}">
        {{ section.settings.home_label }}
      </a>

      {% if section.settings.product_page != blank %}
        <a href="{{ section.settings.product_page.url }}">
          {{ section.settings.product_label }}
        </a>
      {% else %}
        <a href="/collections/all">
          {{ section.settings.product_label }}
        </a>
      {% endif %}

    </nav>

    <a href="/cart" class="cart">
      <svg class="cart-icon" viewBox="0 0 24 24">
        <path d="M7 4h-2l-1 2h2l3.6 7.59-1.35 2.44c-.16.28-.25.61-.25.97 
        0 1.1.9 2 2 2h9v-2h-8.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h5.94
        c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.3.12-.48
        0-.55-.45-1-1-1h-14.31l-.94-2zm3 16c-1.1 0-2 .9-2 2s.9 2 2 2 
        2-.9 2-2-.9-2-2-2zm8 0c-1.1 0-2 .9-2 2s.9 2 2 2 
        2-.9 2-2-.9-2-2-2z"/>
      </svg>

      <span id="cart-count">0</span>
    </a>

  </div>
</header>

{% schema %}
{
  "name": "Header Navigation",
  "settings": [
    {
      "type": "text",
      "id": "home_label",
      "label": "Texto Home",
      "default": "Início"
    },
    {
      "type": "text",
      "id": "product_label",
      "label": "Texto Produto",
      "default": "Produto"
    },
    {
      "type": "product",
      "id": "product_page",
      "label": "Selecionar produto"
    }
  ]
}
{% endschema %}