
<div class="banner-slider-principal banner-slider-principal--{{ section.id }}">
    <div class="blaze-slider">
      <div class="blaze-container">
        <div class="blaze-track-container">
          <div class="blaze-track">
            {% for block in section.blocks %}
              <div class=" slider-banner slider-banner--{{ block.id }}">
                <div class="image-container">
                    <img class="desktop" width="auto" height="auto" src="{{block.settings.image_desktop | img_url: 'nil' }}" alt="Banner Desktop">
                </div>
                <div class="content">
                    <div class="title">
                        {{ block.settings.title }}
                    </div>
                    <div class="description">
                        {{ block.settings.description }}
                    </div>
                    <a class="btn-banner" href="{{block.settings.btn_link}}">{{ block.settings.btn_text }}</a>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
    
        <button class="blaze-prev btn-banner-prev">{{ 'arrow-prev-svgrepo-com.svg'|inline_asset_content }}</button>
        <button class="blaze-next btn-banner-next">{{ 'arrow-next-svgrepo-com.svg'|inline_asset_content }}</button>
        <div class="blaze-pagination"></div>
      </div>
    </div>
</div>

<link
  rel="stylesheet"
  href="https://unpkg.com/blaze-slider@latest/dist/blaze.css"
/>
<script src="https://unpkg.com/blaze-slider@latest/dist/blaze-slider.min.js"></script>

<style>
    .banner-slider-principal{
        .blaze-slider{
            position: relative;
            .blaze-container{
                .blaze-track-container{
                    .blaze-track{
                        .slider-banner{
                            position: relative;
                            .image-container{
                                .desktop{
                                    display: block;
                                }
                            }

                            .content{
                                position: absolute;
                                top: 0;
                                bottom: 0;
                                right: 0;
                                left: 0;
                                width: 100%;
                                height: 100%;
                                max-width: 90vw;
                                margin: 0 auto;

                                display: flex;
                                flex-direction: column;
                                justify-content: center;
                                gap: 1rem;

                                .title{
                                    margin: 0;
                                    font-size: 5rem;
                                    font-weight: 600;
                                    line-height: normal;
                                    font-style: normal;
                                    p{
                                        margin: 0;
                                    }
                                }

                                .description{
                                    margin: 0;
                                    font-size: 1.8rem;
                                    color: #fff;
                                    font-weight: 400;
                                    line-height: normal;
                                    font-style: normal;
                                    max-width: 45%;
                                    p{
                                        margin: 0;
                                    }
                                }

                                .btn-banner{
                                padding: 1rem 3rem;
                                background-color: #000;
                                text-decoration: none;
                                color: #fff;
                                font-size: 1.6rem;

                                }
                            }
                            
                        }
                    }
                }
            }

            .btn-banner-prev, .btn-banner-next{
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                border: none;
                background: transparent;
                width: 3rem;
                height: 3rem;
                cursor: pointer;

                svg{
                    width: 100%;
                    display: block;
                    height: 100%;
                    color: #fff;
                }
            }

            .btn-banner-prev{
                left: 10px;
            }

            .btn-banner-next{
                right: 10px;
            }

            .blaze-pagination{
                position: absolute;
                bottom: 0;
                margin: 0 0 2rem 0;
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 1rem;

                button{
                    width: 1rem;
                    height: 1.3rem;
                    border-radius: 50%;
                    background-color: transparent;
                    border: 1px solid #fff;
                    font-size: 0;
                    transition: all 0.3s ease-in-out;

                    &.active{
                        width: 6rem;
                        height: 1.3rem;
                        background-color: #fff;
                        border-radius: 5px;
                    }
                }
            }
        }
    }
</style>

<style>
    {%  for block in section.blocks %}
        .banner-slider-principal--{{ section.id }}{
            .blaze-slider{
                .blaze-container{
                    .blaze-track-container{
                        .blaze-track{
                            .slider-banner--{{ block.id }}{
                                .content{
                                    --position-horizontal-desktop: {{ block.settings.position_horizontal_desktop }};
                                    align-items: var(--position-horizontal-desktop);
                                    --position-vertical-desktop: {{ block.settings.position_vertical_desktop }};
                                    justify-content: var(--position-vertical-desktop);

                                    .title{
                                        --color-text:{{
                                            block.settings.color_text
                                        }};
                                        color: var(--color-text);
                                    }

                                    .description{
                                        --color-text:{{
                                            block.settings.color_text
                                        }};
                                        color: var(--color-text);
                                    }

                                    .btn-banner{
                                        --color-btn-text: {{ block.settings.color_text_btn }};
                                        --color-btn-bg: {{ block.settings.color_bg_btn }};
                                        background-color: var(--color-btn-bg);
                                        color: var(--color-btn-text);
                                    }
                                }
                                
                            }
                        }
                    }
                }
            }
        }
    {% endfor %}
</style>

<script>
    document.addEventListener('DOMContentLoaded', function(){
        const el = document.querySelector('.blaze-slider');
        new BlazeSlider(el, {
        all: {
            //enableAutoplay: false,
            //autoplayInterval: 2000,
            transitionDuration: 300,
            slidesToShow: 1,
            draggable: true,
            loop: true,
            enablePaggination: true,
            enableNavigation: true
        }
        });
    })
</script>

{% schema %}
  {
    "name": "Hero Slider",
    "settings": [
    
    ],
    "blocks": [
        {
            "name": "image",
            "type": "image",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image_desktop",
                    "label": "Image Desktop"
                },
                {
                    "type": "richtext",
                    "id": "title",
                    "label": "Digite o titulo do Banner",
                    "default": "<p>DUFFEL PACK</p>"
                },
                {
                    "type": "richtext",
                    "id": "description",
                    "label": "Digite a descrição do Banner",
                    "default": "<p>Formas e proporções são para o seu intelecto. Tratei coleta como se fosse um espartilho</p>"
                },
                {
                    "type": "text",
                    "id": "btn_text",
                    "label": "Texto do botão"
                },
                {
                    "type": "url",
                    "id": "btn_link",   
                    "label": "Link do Botão"
                },
                {
                    "type": "header",
                    "content": "CORES"
                },
                {
                    "type": "color",
                    "id": "color_text",
                    "default": "#fff",
                    "label": "Cor dos textos"    
                },
                {
                    "type": "color",
                    "id": "color_text_btn",
                    "default": "#fff",
                    "label": "Cor do texto do botão"
                },
                {
                    "type": "color",
                    "id": "color_bg_btn",
                    "default": "#fff",
                    "label": "Cor de fundo do botão"
                },
                {
                    "type": "header",
                    "content": "Posição Horizontal"
                },
                {
                    "type": "select",
                    "id": "position_horizontal_desktop",
                    "label": "Posição Horizontal Desktop",
                    "default": "flex-start",
                    "options": [
                        {
                            "value": "flex-start",
                            "label": "Esquerda"
                        },
                        {
                            "value": "center",
                            "label": "Centro"
                        },
                        {
                            "value": "flex-end",
                            "label": "Direita"
                        }
                    ]
                },
                {
                    "type": "header",
                    "content": "Posição Vertical"
                },
                {
                    "type": "select",
                    "id": "position_vertical_desktop",
                    "label": "Posição Vertical Desktop",
                    "default": "center",
                    "options": [
                        {
                            "value": "flex-start",
                            "label": "Topo"
                        },
                        {
                            "value": "center",
                            "label": "Centro"
                        },
                        {
                            "value": "flex-end",
                            "label": "Bottom"
                        }
                    ]
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Banner Aula"
        }
    ]
  }
{% endschema %}